import numpy as np
import matplotlib.pyplot as plt
import sympy as sp

# 1. Derivación analítica con SymPy
t_sym = sp.Symbol('t')
A = 1

x_sym = A * sp.exp(-1/3 * t_sym) * sp.cos(2 * sp.pi * t_sym + sp.pi / 4)
v_sym = sp.diff(x_sym, t_sym)   # Primera derivada (Velocidad)
a_sym = sp.diff(v_sym, t_sym)   # Segunda derivada (Aceleración)

# 2. Conversión a funciones numéricas
x_func = sp.lambdify(t_sym, x_sym, 'numpy')
v_func = sp.lambdify(t_sym, v_sym, 'numpy')
a_func = sp.lambdify(t_sym, a_sym, 'numpy')

# Evaluación en el intervalo de 0 a 6 s
t_val = np.linspace(0, 6, 500)
x_val = x_func(t_val)
v_val = v_func(t_val)
a_val = a_func(t_val)

# 3. Creación de subplots compartiendo el eje x
fig, axs = plt.subplots(3, 1, figsize=(8, 10), sharex=True)

# Primera gráfica: Posición (Color rojo)
axs[0].plot(t_val, x_val, color='red', label='Posición x(t)')
axs[0].set_title('Análisis Cinemático')
axs[0].set_ylabel('Posición (m)')
axs[0].grid(True)
axs[0].legend()

# Segunda gráfica: Velocidad (Color azul)
axs[1].plot(t_val, v_val, color='blue', label='Velocidad v(t)')
axs[1].set_ylabel('Velocidad (m/s)')
axs[1].grid(True)
axs[1].legend()

# Tercera gráfica: Aceleración
axs[2].plot(t_val, a_val, color='green', label='Aceleración a(t)')
axs[2].set_xlabel('Tiempo (s)')
axs[2].set_ylabel('Aceleración (m/s²)')
axs[2].grid(True)
axs[2].legend()

plt.tight_layout()
plt.show()

